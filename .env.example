# Folio 环境变量配置

# 管理员账户（首次启动时创建）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# JWT
JWT_SECRET_KEY=changeme-to-a-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=525600
REFRESH_TOKEN_EXPIRE_DAYS=365

# 数据库
DATABASE_URL=sqlite:///data/folio.db

# 文件存储
BOOKS_STORAGE_PATH=/data/books

# 元数据源
METADATA_PROVIDERS=douban,isbn_cn,google_books,open_library
GOOGLE_BOOKS_API_KEY=

# OPDS
OPDS_ENABLED=true
OPDS_ALLOW_ANONYMOUS=false

# 上传
MAX_UPLOAD_SIZE=104857600
ALLOWED_FORMATS=epub,pdf,mobi,azw3,cbz,txt,djvu

# 日志
LOG_LEVEL=info
